{
  "manifest_version": 3,
  "name": "Genichiro Translator",
  "version": "1.1",
  "description": "مترجم ذكي بنمط يدعم المرادفات وتصحيح الإملاء.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://translate.googleapis.com/*"
  ],
  


"action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },

  
  "browser_specific_settings": {
    "gecko": {
      "id": "genichiro-translator@yourdomain.com",
      "strict_min_version": "109.0"
    }
  }
}
